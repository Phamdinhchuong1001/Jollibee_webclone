@page
@model JollibeeClone.Pages.News.IndexModel
@{
    ViewData["Title"] = "Tin Tức & Sự Kiện";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/news-section.css" asp-append-version="true" />
}

<div class="news-page">
    <div class="news-header">
        <div class="container">
            <div class="text-center">
                <h1 class="news-title">TIN TỨC & SỰ KIỆN</h1>
                <p>Trạng thái hệ thống: @Model.ConnectionTest</p>
                <p class="news-subtitle">Tận hưởng những khoảnh khắc trọn vẹn cùng Jollibee</p>
            </div>
        </div>
    </div>

    <div class="news-section">
        <div class="container">
            @if (!Model.NewsList.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-newspaper"></i>
                    <h3>Hiện tại chưa có tin tức nào</h3>
                    <p>Hãy quay lại sau để cập nhật những thông tin mới nhất từ Jollibee!</p>
                </div>
            }
            else
            {
                <div class="row g-4" id="newsContainer">
                    @foreach (var news in Model.NewsList)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="news-card" data-news-title="@news.Title">
                                <div class="news-image">
                                    @if (!string.IsNullOrEmpty(news.ImageUrl))
                                    {
                                        <img src="@news.ImageUrl" alt="@news.Title" class="img-fluid">
                                    }
                                    else
                                    {
                                        <div class="news-placeholder">
                                            <i class="fas fa-newspaper"></i>
                                        </div>
                                    }
                                    <div class="news-badge">TIN TỨC</div>
                                </div>

                                <div class="news-content">
                                    <h3 class="news-card-title">@news.Title</h3>

                                    @if (!string.IsNullOrEmpty(news.ShortDescription))
                                    {
                                        <p class="news-description">@news.ShortDescription</p>
                                    }

                                    <div class="news-meta">
                                        <div class="news-date">
                                            <i class="fas fa-calendar"></i>
                                            @news.PublishedDate.ToString("dd/MM/yyyy")
                                        </div>
                                        <div class="news-author">
                                            <i class="fas fa-user"></i>
                                            @news.AuthorName
                                        </div>
                                    </div>
                                </div>

                                <div class="news-overlay">
                                    <div class="news-overlay-content">
                                        <h5>@news.Title</h5>
                                        <p>@(news.ShortDescription ?? "Đọc để khám phá nội dung thú vị...")</p>
                                        <button class="btn-view-detail" data-news-id="@news.NewsID">
                                            <i class="fas fa-book-open"></i> Đọc thêm
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="newsDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold" id="newsModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="newsModalBody">
                @* Content loaded via AJAX *@
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-danger rounded-pill px-4" onclick="shareCurrentNews()">
                    <i class="fas fa-share-alt me-2"></i> Chia sẻ
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentNewsData = null;

        $(document).ready(function() {
            // Sử dụng Event Delegation cho các nút bấm được render động
            $(document).on('click', '.btn-view-detail', function() {
                var newsId = $(this).data('news-id');
                loadNewsDetail(newsId);
            });
        });

        function loadNewsDetail(newsId) {
            // Chú ý: Vẫn gọi qua API của NewsController cũ vì bạn đã viết logic xử lý JSON ở đó
            $.get('/News/GetNewsDetails/' + newsId)
                .done(function(response) {
                    if (response.success) {
                        var news = response.data;
                        currentNewsData = news;
                        $('#newsModalTitle').text(news.title);

                        var modalContent = `
                            <div class="news-detail p-2">
                                ${news.imageUrl ? `<img src="${news.imageUrl}" class="img-fluid rounded-4 mb-4 shadow-sm">` : ''}
                                <div class="d-flex justify-content-between text-muted small mb-3">
                                    <span><i class="fas fa-calendar me-1"></i> ${new Date(news.publishedDate).toLocaleDateString('vi-VN')}</span>
                                    <span><i class="fas fa-user me-1"></i> ${news.authorName}</span>
                                </div>
                                <h4 class="fw-bold text-danger mb-3">${news.title}</h4>
                                <div class="news-content-detail">
                                    ${news.content}
                                </div>
                            </div>
                        `;

                        $('#newsModalBody').html(modalContent);
                        $('#newsDetailModal').modal('show');
                    }
                });
        }

        function shareCurrentNews() {
            if (currentNewsData && navigator.share) {
                navigator.share({
                    title: currentNewsData.title,
                    url: window.location.origin + '/News#news-' + currentNewsData.newsID
                });
            } else {
                alert('Chức năng chia sẻ đang được cập nhật!');
            }
        }
    </script>
}